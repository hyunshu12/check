{
  "ci": {
    "collect": {
      "url": [
        "http://127.0.0.1:4174/"
      ],
      "numberOfRuns": 2,
      "startServerCommand": "npm run preview -- --host 127.0.0.1 --port 4174 --strictPort",
      "startServerReadyPattern": "http://127\\.0\\.0\\.1:4174/",
      "settings": {
        "chromeFlags": "--headless=new --no-sandbox"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "error",
          {
            "minScore": 0.95
          }
        ],
        "largest-contentful-paint": [
          "error",
          {
            "maxNumericValue": 1800
          }
        ],
        "cumulative-layout-shift": [
          "error",
          {
            "maxNumericValue": 0.1
          }
        ],
        "total-blocking-time": [
          "error",
          {
            "maxNumericValue": 100
          }
        ]
      }
    }
  }
}
